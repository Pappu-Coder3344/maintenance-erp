
# Common
APP_NAME=Garments Maintenance ERP
APP_ENV=development

# API
API_PORT=4000
API_BASE_URL=http://localhost:4000/api/v1
JWT_ACCESS_SECRET=replace_with_access_secret
JWT_REFRESH_SECRET=replace_with_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/garments_maintenance_erp

# Storage
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=maintenance-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123

# Email / SMS hooks
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=maintenance-alerts@example.com
SMTP_PASS=change-me
SMS_PROVIDER_URL=https://sms.example.com/send
